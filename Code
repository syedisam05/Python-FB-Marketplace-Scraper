"""
Facebook Marketplace Monitor
Only opens detail pages for listings whose CARD TEXT contains 4090 or 5090.
Age must be "listed N minutes ago" and within MAX_AGE_MINUTES.

Requirements:
    pip install playwright requests
    playwright install chromium

First-time setup:
    1. Set DISCORD_WEBHOOK_URL below.
    2. Set FORCE_LOGIN = True, run, log in via the browser, press ENTER.
    3. Set FORCE_LOGIN = False for all future runs.
"""

import json
import random
import re
import time
from dataclasses import dataclass
from datetime import datetime
from pathlib import Path
from typing import Optional

import requests
from playwright.sync_api import sync_playwright, TimeoutError as PlaywrightTimeoutError

